<!doctype html>
<html lang="id">
  <head>
    <script>
      (() => {
        try {
          const m = localStorage.getItem('themeMode');
          if (m ? m === 'dark' : matchMedia('(prefers-color-scheme: dark)').matches)
            document.documentElement.classList.add('dark');
        } catch (_) {}
        try {
          const v = localStorage.getItem('themeVariant');
          if (v) document.documentElement.classList.add('theme-' + v);
        } catch (_) {}
        document.addEventListener('basecoat:theme', e => {
          const dark = e.detail?.mode === 'dark' ? true
            : e.detail?.mode === 'light' ? false
            : !document.documentElement.classList.contains('dark');
          document.documentElement.classList.toggle('dark', dark);
          try { localStorage.setItem('themeMode', dark ? 'dark' : 'light'); } catch (_) {}
        });
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= (typeof pageTitle !== 'undefined' && pageTitle) ? pageTitle : 'Dashboard' %> — Pengembalian UKT</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/assets/styles.css" />
    <link rel="stylesheet" href="/stylesheets/style.css" />
    <script src="/assets/js/basecoat.js?v=0.3.11" defer></script>
    <script src="/assets/js/sidebar.js?v=0.3.11"  defer></script>
    <script src="/assets/js/popover.js?v=0.3.11"  defer></script>
  </head>
  <body>
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const sidebar = document.getElementById('sidebar');
        if (!sidebar) return;
        const path = location.pathname.replace(/\/$/, '');
        sidebar.querySelectorAll('a[href]').forEach(a => {
          const ap = new URL(a.href, location.origin).pathname.replace(/\/$/, '');
          ap === path ? a.setAttribute('aria-current','page') : a.removeAttribute('aria-current');
        });
      });
    </script>

    <aside id="sidebar" class="sidebar" data-side="left" aria-hidden="false">
      <nav aria-label="Navigasi sidebar">
        <header>
          <a href="/dashboard" class="flex items-center gap-2.5 px-3 py-3 w-full">
            <div class="flex aspect-square size-6 items-center justify-center rounded-md bg-foreground text-background shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5" aria-hidden="true"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
            </div>
            <span class="text-sm font-semibold tracking-tight">Pengembalian UKT</span>
          </a>
        </header>
        <section class="scrollbar">
          <div role="group" aria-labelledby="group-main">
            <h3 id="group-main">Menu</h3>
            <ul>
              <li><a href="/dashboard" class="flex items-center gap-2.5 rounded-md px-2 py-1.5 text-sm transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>
                Dashboard
              </a></li>
              <li><a href="/ukt/permohonan" class="flex items-center gap-2.5 rounded-md px-2 py-1.5 text-sm transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
                Daftar Permohonan
              </a></li>
              <li><a href="/ukt/periode" class="flex items-center gap-2.5 rounded-md px-2 py-1.5 text-sm transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
                Periode Permohonan
              </a></li>
              <li><a href="/ukt/export" class="flex items-center gap-2.5 rounded-md px-2 py-1.5 text-sm transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                Export Rekap
              </a></li>
            </ul>
          </div>
        </section>
        <footer>
          <div id="popover-user" class="popover">
            <button id="popover-user-trigger" type="button" aria-expanded="false" aria-controls="popover-user-popover"
              class="flex w-full items-center gap-2.5 px-3 py-2.5 text-sm transition-colors" data-keep-mobile-sidebar-open="">
              <div class="flex aspect-square size-7 items-center justify-center rounded-full bg-foreground text-background font-semibold text-xs shrink-0">A</div>
              <div class="grid flex-1 text-left leading-tight">
                <span class="truncate text-sm font-medium">Admin</span>
                <span class="truncate text-xs text-muted"><%= user %></span>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted shrink-0" aria-hidden="true"><path d="m7 15 5 5 5-5"/><path d="m7 9 5-5 5 5"/></svg>
            </button>
            <div id="popover-user-popover" data-popover aria-hidden="true" data-side="top" class="w-[220px]">
              <div class="grid gap-2 p-1">
                <p class="text-xs px-2 pt-1 text-muted">Masuk sebagai <strong><%= user %></strong></p>
                <a href="/logout" class="btn-sm-outline w-full text-center">Keluar</a>
              </div>
            </div>
          </div>
        </footer>
      </nav>
    </aside>

    <main id="content">
      <header class="bg-background sticky inset-x-0 top-0 isolate flex shrink-0 items-center gap-2 border-b z-10">
        <div class="flex h-11 w-full items-center gap-2 px-4">
          <button type="button" onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))"
            aria-label="Toggle sidebar" class="btn-sm-icon-ghost size-7 -ml-1.5 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 3v18"/></svg>
          </button>
          <nav aria-label="breadcrumb" class="text-sm text-muted">
            <span>Pengembalian UKT</span>
           <% const safeBreadcrumbs = typeof breadcrumbs !== 'undefined' ? breadcrumbs : []; %>
           <% safeBreadcrumbs.forEach(function(c) { %>
              <span class="mx-1.5" aria-hidden="true">/</span>
              <% if (c.href) { %><a href="<%- c.href %>"><%= c.label %></a><% } else { %>
              <span class="font-medium" style="color:var(--foreground)"><%= c.label %></span>
              <% } %>
            <% }) %>
          </nav>
          <button type="button" aria-label="Toggle dark mode"
            onclick="document.dispatchEvent(new CustomEvent('basecoat:theme'))"
            class="btn-icon-outline size-8 ml-auto">
            <span class="hidden dark:block" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
            </span>
            <span class="block dark:hidden" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
            </span>
          </button>
        </div>
      </header>

      <div class="p-4 md:p-6">
