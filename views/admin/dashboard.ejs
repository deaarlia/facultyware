<%
  const pageTitle   = 'Dashboard';
  const breadcrumbs = [{ label: 'Dashboard' }];
  const pageScript  = null;

  const safeStats = stats || { total: 0, pending: 0, approved: 0, rejected: 0 };
  const safeRecent = Array.isArray(recent) ? recent : [];
%>
<%- include('../partials/admin-layout', { pageTitle: pageTitle, breadcrumbs: breadcrumbs }) %>

  <div class="mb-6">
    <h1 class="text-2xl font-bold tracking-tight">Dashboard</h1>
    <p class="text-sm mt-1 text-muted">Ringkasan permohonan pengembalian UKT mahasiswa.</p>
  </div>

  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    <div class="card-stat p-0" style="--accent-color: var(--muted-foreground);">
      <section class="p-4 flex flex-col gap-1">
        <div class="flex justify-between items-start w-full">
          <p class="text-xs font-semibold uppercase tracking-wider text-muted">Total Permohonan</p>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted opacity-60" aria-hidden="true"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
        </div>
        <p class="text-3xl font-extrabold mt-1 tracking-tight"><%= safeStats.total %></p>
        <p class="text-xs text-muted">Semua periode</p>
      </section>
    </div>
    <div class="card-stat p-0" style="--accent-color: #f59e0b;">
      <section class="p-4 flex flex-col gap-1">
        <div class="flex justify-between items-start w-full">
          <p class="text-xs font-semibold uppercase tracking-wider text-muted">Menunggu Verifikasi</p>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-70" style="color: #f59e0b;" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <p class="text-3xl font-extrabold mt-1 tracking-tight" style="color: #f59e0b;"><%= safeStats.pending %></p>
        <p class="text-xs text-muted">Perlu ditindaklanjuti</p>
      </section>
    </div>
    <div class="card-stat p-0" style="--accent-color: #22c55e;">
      <section class="p-4 flex flex-col gap-1">
        <div class="flex justify-between items-start w-full">
          <p class="text-xs font-semibold uppercase tracking-wider text-muted">Disetujui</p>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-70" style="color: #22c55e;" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <p class="text-3xl font-extrabold mt-1 tracking-tight" style="color: #22c55e;"><%= safeStats.approved %></p>
        <p class="text-xs text-muted">Lolos verifikasi Tahap 1</p>
      </section>
    </div>
    <div class="card-stat p-0" style="--accent-color: #ef4444;">
      <section class="p-4 flex flex-col gap-1">
        <div class="flex justify-between items-start w-full">
          <p class="text-xs font-semibold uppercase tracking-wider text-muted">Ditolak</p>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-70" style="color: #ef4444;" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        </div>
        <p class="text-3xl font-extrabold mt-1 tracking-tight" style="color: #ef4444;"><%= safeStats.rejected %></p>
        <p class="text-xs text-muted">Tidak memenuhi syarat</p>
      </section>
    </div>
  </div>

  <div class="card p-0">
    <header class="p-4 md:p-5 flex items-center justify-between border-b">
      <div>
        <h2 class="font-semibold">Permohonan Terbaru</h2>
        <p class="text-sm text-muted">8 permohonan terakhir masuk</p>
      </div>
      <a href="/ukt/permohonan" class="btn-sm-outline">Lihat Semua</a>
    </header>
    <section class="p-0">
      <% if (safeRecent.length === 0) { %>
        <div class="p-8 text-center text-sm text-muted">Belum ada permohonan masuk.</div>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="table w-full">
            <thead>
              <tr>
                <th>No. Permohonan</th>
                <th>Nama Mahasiswa</th>
                <th>NIM</th>
                <th>Nominal</th>
                <th>Tanggal</th>
                <th>Status</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% safeRecent.forEach(function(r) { %>
                <% 
                  const nominal = r.refund_nominal 
                    ? 'Rp ' + parseInt(r.refund_nominal).toLocaleString('id-ID') 
                    : '—';

                  const tgl = r.requested_at
                    ? new Date(r.requested_at).toLocaleDateString('id-ID', { day:'2-digit', month:'short', year:'numeric' })
                    : '—';
                %>
                <tr>
                  <td class="font-mono text-sm">#<%= r.id %></td>
                  <td class="font-medium"><%= r.nama_mahasiswa || r.student_name %></td>
                  <td class="text-muted font-mono text-sm"><%= r.nim || r.regno %></td>
                  <td class="text-sm font-medium"><%= nominal %></td>
                  <td class="text-sm text-muted"><%= tgl %></td>
                  <td>
                    <% if (r.status === 0 || r.status_code === 0) { %>
                      <span class="badge badge-warning">Menunggu</span>
                    <% } else if (r.status === 1 || r.status_code === 1) { %>
                      <span class="badge badge-success">Disetujui</span>
                    <% } else if (r.status === 2 || r.status_code === 2) { %>
                      <span class="badge badge-destructive">Ditolak</span>
                    <% } else { %>
                      <span class="badge">Draft</span>
                    <% } %>
                  </td>
                  <td><a href="/ukt/permohonan/<%= r.id %>" class="btn-sm-outline">Detail</a></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </section>
  </div>

<%- include('../partials/admin-footer') %>